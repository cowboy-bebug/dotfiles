[alias]
	set-personal = !git config --local user.email "cowboy-bebug@users.noreply.github.com" && \
	                git config --local user.signingkey "4E73B55E" && \
	                git config --local github.user "cowboy-bebug" && \
	                git config --local gitlab.user "cowboy-bebug"
	set-work = !git config --local user.email "eric-lim@idexx.com" && \
	            git config --local user.signingkey "C2711835" && \
	            git config --local github.user "eric-lim_idxx" && \
	            git config --local gitlab.user "eric-lim-idexx"

[commit]
	gpgsign = true
[core]
	ignorecase = false
	pager = less -F -X
[credential "https://github.com"]
	helper =
	helper = !/opt/homebrew/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper =
	helper = !/opt/homebrew/bin/gh auth git-credential
[credential "https://gitlab.com"]
	helper =
	helper = !/opt/homebrew/bin/glab auth git-credential
[diff]
	wsErrorHighlight = all
[format]
	pretty = oneline
[init]
	defaultBranch = main
[log]
	abbrevCommit = true
[pull]
	rebase = true
[push]
	autoSetupRemote = true
[user]
	name = Eric Lim
	email = cowboy-bebug@users.noreply.github.com
	signingkey = 4E73B55E
[github]
	user = cowboy-bebug
[gitlab]
	user = cowboy-bebug
[fetch]
	pruneTags = true
	prune = true

# overrides the defaults
[includeIf "gitdir:~/git/"]
	path = ~/.config/git/work.config
[includeIf "gitdir:~/github.com/idexx-laboratories/"]
	path = ~/.config/git/work.config
[includeIf "gitdir:~/gitlab.com/"]
	path = ~/.config/git/work.config
