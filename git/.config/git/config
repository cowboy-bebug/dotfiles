[alias]
	set-personal = !git config --local user.email "cowboy-bebug@users.noreply.github.com" && \
	                git config --local user.signingkey "4E73B55E"
	set-work = !git config --local user.email "eric-lim@idexx.com" && \
	            git config --local user.signingkey "C2711835"
[commit]
	gpgsign = true
[core]
	ignorecase = false
	pager = delta
[delta]
	line-numbers = true
	navigate = true
	side-by-side = true
[diff]
	wsErrorHighlight = all
[format]
	pretty = oneline
[init]
	defaultBranch = main
[interactive]
	diffFilter = delta --color-only
[log]
	abbrevCommit = true
[merge]
	conflictStyle = zdiff3
[pull]
	rebase = true
[push]
	autoSetupRemote = true
[user]
	name = Eric Lim
[fetch]
	pruneTags = true
	prune = true
